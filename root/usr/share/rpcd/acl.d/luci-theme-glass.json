{
    "luci-theme-glass": {
        "description": "Grant access for luci-theme-glass",
        "read": {
            "uci": [ "glass" ],
            "file": {
                "/www/luci-static/glass/background/*": [ "list", "read" ]
            },
            "ubus": {
                "session": [ "access", "login" ],
                "network.interface": [ "dump" ],
                "network.device": [ "status" ],
                "glass": [ "wallpapers", "current", "getSource", "setSource", "nextBatch" ]
            }
        },
        "write": {
            "uci": [ "glass" ],
            "file": {
                "/www/luci-static/glass/background/*": [ "write" ]
            },
            "ubus": {
                "glass": [ "download", "remove" ]
            }
        }
    }
}
